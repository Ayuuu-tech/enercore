# Copy to .env and fill in real values. Never commit .env.

# Supabase PostgreSQL (use the Session pooler connection string, port 5432)
DATABASE_URL="postgresql://postgres.<project-ref>:<password>@aws-1-<region>.pooler.supabase.com:5432/postgres"

# JWT
JWT_SECRET="change-me"
JWT_EXPIRES_IN="7d"

# Server
PORT=3000

# Supabase project
SUPABASE_URL="https://<project-ref>.supabase.co"
SUPABASE_KEY="<publishable-key>"

# Trackso Telemetry API
TRACKSO_BASE_URL="https://prodapi.trackso.in"
TRACKSO_AUTH_HEADER="<trackso-app-authorization-header>"
TRACKSO_EMAIL="<trackso-account-email>"
TRACKSO_PASSWORD="<trackso-account-password>"
# Comma-separated Trackso site keys
TRACKSO_SITE_KEYS="<siteKey1>,<siteKey2>"

# IO.Next Telemetry API (for IONEXT plants)
IONEXT_BASE_URL="https://backend2.ionest.cloud/api"
IONEXT_USERNAME="<ionext-username>"
IONEXT_PASSWORD="<ionext-password>"
