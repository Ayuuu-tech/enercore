// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  CLIENT
  ADMIN
  VENDOR
}

enum PanelStatus {
  HEALTHY
  WARNING
  FAULT
  OFFLINE
}

enum InvoiceStatus {
  PAID
  OVERDUE
  PENDING
}

enum OrderStatus {
  PENDING
  SHIPPED
  DELIVERED
  CANCELLED
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
}

enum SubscriptionPlan {
  MONTHLY
  YEARLY
}

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
  PENDING
  SUSPENDED
  CANCELLED
}

enum PaymentStatus {
  SUCCESS
  PENDING
  FAILED
  REFUNDED
}

model User {
  id             String          @id @default(uuid())
  email          String          @unique
  password       String
  name           String
  role           Role            @default(CLIENT)
  isActive       Boolean         @default(true)
  // Modules/features this user may access. Empty = all (default).
  modules        String[]        @default([])
  phone          String?
  company        String?
  gstNumber      String?
  postalCode     String?
  address        String?
  avatarUrl      String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  plants         Plant[]
  plantAccess    PlantAccess[]
  tickets        Ticket[]
  ticketComments TicketComment[]
  orders         Order[]
  notifications  Notification[]
  invoices       Invoice[]
  vendorProfile  Vendor?
  subscriptions  Subscription[]
  payments       Payment[]
}

// A user's subscription period. Admin-managed (no external gateway).
model Subscription {
  id         String             @id @default(uuid())
  userId     String
  user       User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan       SubscriptionPlan   @default(MONTHLY)
  status     SubscriptionStatus @default(PENDING)
  amount     Float              @default(0)
  startDate  DateTime           @default(now())
  expiryDate DateTime
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt
  payments   Payment[]

  @@index([userId])
  @@index([status])
}

// Immutable trail of admin actions.
model AuditLog {
  id         String   @id @default(uuid())
  actorId    String
  actorName  String
  action     String
  targetType String?
  targetId   String?
  detail     String?
  createdAt  DateTime @default(now())

  @@index([createdAt])
  @@index([actorId])
}

// A payment record. Can be linked to a subscription.
model Payment {
  id             String        @id @default(uuid())
  userId         String
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscriptionId String?
  subscription   Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  amount         Float
  status         PaymentStatus @default(PENDING)
  method         String?
  reference      String?
  paidAt         DateTime?
  createdAt      DateTime      @default(now())

  @@index([userId])
  @@index([status])
}

// Grants a user access to a plant they do not own (many-to-many).
// Effective plant access = plants owned + plants granted here.
model PlantAccess {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  plantId   String
  plant     Plant    @relation(fields: [plantId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, plantId])
  @@index([userId])
  @@index([plantId])
}

model Vendor {
  id          String   @id
  user        User     @relation(fields: [id], references: [id], onDelete: Cascade)
  companyName String
  rating      Float    @default(0.0)
  isVerified  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  products    Product[]
}

enum PlantDataSource {
  TRACKSO
  IONEXT
}

model Plant {
  id           String          @id @default(uuid())
  name         String
  location     String
  peakCapacity Float
  status       String
  // Where this plant's live data comes from, and its key in that provider
  // (Trackso siteKey or IO.Next plant pk).
  dataSource   PlantDataSource @default(TRACKSO)
  externalKey  String?
  // Billing profile — printed on the monthly solar bill of supply.
  tariff          Float   @default(0) // Rs per kWh, per the PPA
  legalName       String? // "M/s HELLA INDIA AUTOMOTIVE PRIVATE LIMITED"
  gstin           String?
  billingAddress  String?
  offtakerCode    String?
  ownerId      String
  owner        User        @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  panels       Panel[]
  tickets      Ticket[]
  telemetry    Telemetry[]
  invoices     Invoice[]
  accessGrants PlantAccess[]
  dailyEnergy  DailyEnergy[]
}

// One row per plant per calendar day (IST). Providers that don't expose
// historical data (e.g. IO.Next) get their day's energy snapshotted here on
// every sync, so week/month/year totals can be served from our own database.
model DailyEnergy {
  id          String   @id @default(uuid())
  plantId     String
  plant       Plant    @relation(fields: [plantId], references: [id], onDelete: Cascade)
  day         String   // IST calendar day, "YYYY-MM-DD"
  energyKwh   Float    @default(0)
  lifetimeMwh Float    @default(0)
  updatedAt   DateTime @updatedAt

  @@unique([plantId, day])
  @@index([plantId, day])
}

model Panel {
  id          String      @id @default(uuid())
  row         Int
  column      Int
  status      PanelStatus @default(HEALTHY)
  voltage     Float
  current     Float
  temperature Float
  generation  Float
  lastSync    DateTime    @default(now())
  plantId     String
  plant       Plant       @relation(fields: [plantId], references: [id], onDelete: Cascade)
  telemetry   Telemetry[]
}

model Telemetry {
  id          String   @id @default(uuid())
  voltage     Float
  current     Float
  temperature Float
  generation  Float
  timestamp   DateTime @default(now())
  // Null for providers that report at inverter/plant level rather than
  // per-panel (e.g. IO.Next). Series queries group by plantId only.
  panelId     String?
  panel       Panel?   @relation(fields: [panelId], references: [id], onDelete: Cascade)
  plantId     String
  plant       Plant    @relation(fields: [plantId], references: [id], onDelete: Cascade)

  @@index([timestamp])
  @@index([plantId, timestamp])
}

model Invoice {
  id            String        @id @default(uuid())
  invoiceNumber String        @unique
  amount        Float
  period        String // "May 2026" — the billed calendar month
  status        InvoiceStatus @default(PENDING)
  dueDate       DateTime
  paidAt        DateTime?
  // Solar bill of supply details (null on legacy/manual invoices).
  units         Float?    // billed generation, kWh
  tariff        Float?    // Rs per kWh applied
  billDate      DateTime? // 1st of the month following the period
  periodStart   DateTime?
  periodEnd     DateTime?
  startReading  Float? // cumulative plant generation at period start, kWh
  endReading    Float? // cumulative plant generation at period end, kWh
  userId        String
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  plantId       String?
  plant         Plant?        @relation(fields: [plantId], references: [id], onDelete: SetNull)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  // One bill per plant per month — makes generation safely re-runnable.
  @@unique([plantId, period])
}

model Product {
  id            String      @id @default(uuid())
  title         String
  brand         String
  spec          String
  rating        Float       @default(0.0)
  reviewsCount  Int         @default(0)
  price         Float
  originalPrice Float?
  isAssured     Boolean     @default(false)
  category      String
  stock         Int         @default(0)
  vendorId      String
  vendor        Vendor      @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  orderItems    OrderItem[]
}

model Order {
  id          String      @id @default(uuid())
  orderNumber String      @unique
  totalAmount Float
  status      OrderStatus @default(PENDING)
  userId      String
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  items       OrderItem[]
}

model OrderItem {
  id              String   @id @default(uuid())
  orderId         String
  order           Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId       String
  product         Product  @relation(fields: [productId], references: [id], onDelete: Restrict)
  quantity        Int
  priceAtPurchase Float
}

model Ticket {
  id                String         @id @default(uuid())
  ticketNumber      String         @unique
  title             String
  description       String
  status            TicketStatus   @default(OPEN)
  priority          TicketPriority @default(MEDIUM)
  lastUpdateMessage String?
  userId            String
  user              User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  plantId           String
  plant             Plant          @relation(fields: [plantId], references: [id], onDelete: Cascade)
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  comments          TicketComment[]
}

model TicketComment {
  id        String   @id @default(uuid())
  ticketId  String
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  message   String
  createdAt DateTime @default(now())
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}
